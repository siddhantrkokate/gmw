<body>

<!-- header -->
<div id="header-primary-container" class="poppins-regular">
    
    <div id="header-secondary-container">
        
        <!-- logo -->
        <div id="header-logo-container" onclick="openMyPage('https://www.nismwala.com')">
            <div id="header-logo-first">NISM</div>
            <div id="header-logo-second">wala.com</div>
        </div>
        
        <!-- header navigation menu -->
        <div id="header-nav-container">
            <div class="header-nav-menu home-nav" onclick="openMyPage('https://www.nismwala.com')">
                <i class="fa-solid fa-house"></i>
                Home
            </div>
            <div class="header-nav-menu course-nav" onclick="openMyPage('https://www.nismwala.com/courses/')">
                <i class="fa-solid fa-laptop"></i>
                Courses
            </div>
            <div class="header-nav-menu blogs-nav" onclick="openMyPage('https://www.nismwala.com/blogs')">
                <i class="fa-solid fa-newspaper"></i>
                Blogs
            </div>
        </div>
        
        <div id='header-profile-icon' onclick='openPage()'>S</div>
        
        
    </div>
</div>


<!-- Bottom navigation for mobile -->
<div id="bottom-nav-container" class="poppins-regular">
    <div id="bottom-nav-menu-home" onclick="openMyPage('https://www.nismwala.com')">
        <i class="fa-solid fa-house"></i>
        Home
    </div>
    <div id="bottom-nav-menu-course" onclick="openMyPage('https://www.nismwala.com/courses')">
        <i class="fa-solid fa-laptop"></i>
        Courses
    </div>
    <div id="bottom-nav-menu-blogs" onclick="openMyPage('https://www.nismwala.com/blogs')">
        <i class="fa-solid fa-newspaper"></i>
        Blogs
    </div>
</div>


<!-- Slide-in Login Form -->
<div id="overlay-login" class="poppins-regular"></div>
<div id="login-form-container">
    
    <!-- close button -->
    <div id="login-form-close">×</div>
    
    <!-- login form content -->
    <div id="login-form-content-container" class="poppins-regular">
        
        <!-- login heading -->
        <div id="auth-heading">Login</div>
        <!-- login extra feilds-->
        <div id="login-form-sec-container">
            <input type="email" class="poppins-regular" id="login-name-feild" placeholder="Email" autocomplete="off">
            <input type="password" class="poppins-regular" id="login-password-feild" placeholder="Password" autocomplete="off">
            <div id="login-rect-text">Email or Password Incorrect!</div>
            <div id="login-submit-btn">Submit</div>
            <div id="forgot-password-link">Forgot your password? <span style="color: #3c495b; border-bottom: 2px dotted #3c495b;font-weight: 500; cursor: pointer;">Click here to reset it.</span></div>
        </div>
    </div>
</div>


<!-- Slide-in Register Form -->
<div id="overlay-register"></div>
<div id="register-form-container">
    
    <!-- close button -->
    <div id="register-form-close">×</div>
    
    <!-- heading of registration screeen -->
    <div id="registration-heading" class="poppins-regular">Registration</div>
    
    <!-- screen 1 -->
    <div id="registration-form-screen-1-container" class="poppins-regular">
        
        <!-- email -->
        <input type="email" placeholder="Email" class="poppins-regular" id="registration-email-feild" autocomplete="off">
        
        <!-- phone number -->
        <div id="registration-phone-feild-container">
            <div id="registration-phone-feild-flag-container">
                <img src="https://nismwala.com/web-images/india-flag-24x24.png" id="registration-phone-feild-flag">
            </div>
            <div id="registration-phone-input-container">
                <input type="text" placeholder="Phone no." id="registration-phone-feild" class="poppins-regular" autocomplete="off">
            </div>
        </div>
        
        <!-- rect text screen 1-->
        <div id="registration-screen-1-rect-text">Email already existed!</div>
        
        <!-- next button screen 1 -->
        <div id="registration-screen-1-next-button">Next</div>
        
    </div>
    
    <center>
    <!-- screen 2 -->
    <div id="registration-form-screen-2-container" class="poppins-regular">
        <input type="text" placeholder="Enter verification code" class="poppins-regular" id="registration-verfication-code-feild" autocomplete="off">
        
        <!-- rect text screen 2-->
        <div id="registration-screen-2-rect-text">Hello</div>
        
        <!-- next button screen 2 -->
        <div id="registration-screen-2-verify-button">verify (Code sent to email)</div>
        
        <!-- back to email button -->
        <div id="registration-screen-2-back-to-screen-1-button">Back</div>
    </div>
    
    <!-- screen 3 -->
    <div id="registration-form-screen-3-container" class="poppins-regular">
        <input type="text" placeholder="Create a new password" class="poppins-regular" id="registration-password-feild" autocomplet="off">
        <div id="registration-screen-3-rect-text">Password must be 8+ chars.</div>
        <div id="registration-screen-3-next-button">Next</div>
    </div>
    
    <!-- screen 4 -->
    <div id="registration-form-screen-4-container" class="poppins-regular">
        <input type="text" placeholder="First name" class="poppins-regular" id="registration-fname-feild">
        <input type="text" placeholder="Last name" class="poppins-regular" id="registration-lname-feild">
        <div id="registration-screen-4-rect-text">First name is required!</div>
        <div id="registration-screen-4-save-button">save</div>
    </div>
    
    <!-- screen 5 -->
    <div id="registration-form-screen-5-container" class="poppins-regular">
        <div id="registration-status-icon"><i class="fa-solid fa-check"></i></div>
        <div id="registration-status-text">Registration Successfull</div>
    </div>
    </center>
</div>

<!-- - - - - - - - - - - - Common - - - - -  - - - - - - - - - - -->
<script>

    // function: Open Profile Page
    function openPage(){
        window.open("https://www.nismwala.com/profile","_Self");
    }
    
    // function: Open any page
    function openMyPage(pageURL){
        window.open(pageURL,"_Self");
    }
    
    // function: Email validation 
    function isValidEmail(email) {
        const emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        return emailPattern.test(email);
    }
    
    // function: Phone Number Validation
    function validatePhoneNumber(phoneNumber) {
        var regex = /^\d+$/;
        return regex.test(phoneNumber);
    }
    
    // function: Current Time Picker
    function storeCurrentClickTime() {
        const currentDate = new Date();
        const formattedDate = currentDate.toLocaleString('en-US', {
            year: 'numeric',
            month: '2-digit',
            day: '2-digit',
            hour: '2-digit',
            minute: '2-digit',
            second: '2-digit',
            hour12: false
        });
        const clickTimeString = formattedDate;
        return clickTimeString;
    }
</script>

<!-- - - - - - - - - - - - Login - - - - - - - - - - - - -->
<script>
    // function: Login
    $("#login-submit-btn").on("click", function(){
        
        let email = $("#login-name-feild").val();
        let password = $("#login-password-feild").val();
        let passwordLength = password.length;
        
        if(!isValidEmail(email)){
            $("#login-rect-text").slideDown().text("Please enter a valid email address.").css("color","red");
        }else if(password==""){
            $("#login-rect-text").slideDown().text("Password cannot be empty.").css("color","red");
        }else{
            $("#login-rect-text").slideDown().text("Validating credentials, please wait...").css("color","green");    
            $.ajax({
                url: '/authentication/login-data-validate.php',
                type: 'POST',
                data: {
                    email: email,
                    password: password
                },
                success: function(responselog){
                    if(responselog){
                        location.reload();
                    }else{
                        $("#login-rect-text").slideDown().text("Email or Password invalid!").css("color","red");
                    }
                }
            })
        }
    });
    
    // function : click on forgot password link
    $("#forgot-password-link").on("click", function(){
        window.open('https://www.nismwala.com/reset-password/ ','_Self');
    })
    
    document.getElementById('login-form-close').addEventListener('click', function() {
        document.getElementById('overlay-login').classList.remove('active');
        document.getElementById('login-form-container').classList.remove('active');
        $('#login-name-feild').val('');
        $('#login-password-feild').val('');
        $('#login-rect-text').slideUp();
    });
</script>

<!-- - - - - - - - - - - - - - - -  registration - - - - - - - - - - - - - - -->
<script>
    let email_regi = $("#registration-email-feild").val();
    let phone_no = $("#registration-phone-feild").val();
    let attempts = 0;
    let currentClickTime = storeCurrentClickTime();
    let password_regi = "";
    let fname = "";
    let lname = "";

    // validate email wheen user will click on screen 1 next button
    $("#registration-screen-1-next-button").on("click",function(){
        
        email_regi = $("#registration-email-feild").val();
        phone_no = $("#registration-phone-feild").val();
        currentClickTime = storeCurrentClickTime();
        
        if(!isValidEmail(email_regi)){
            $("#registration-screen-1-rect-text").slideDown().text("Please enter a valid email address.").css("color","red");
        }else if((phone_no.length > 10 || phone_no.length < 10)){
            $("#registration-screen-1-rect-text").slideDown().text("Please enter a valid phone number.").css("color","red");
        }else if(validatePhoneNumber(phone_no)==false){
            $("#registration-screen-1-rect-text").slideDown().text("Please enter a valid phone number.").css("color","red");
        }else{
            $("#registration-screen-1-rect-text").slideDown().text("Checking if user exists, please wait...").css("color","green");
            
            $.ajax({
            url: '/authentication/email-check.php', // Replace with your server endpoint
            type: 'POST',
            data: {email: email_regi},
            success: function(response) {
                // Handle success response
                if(response==true){
                    
                    $.ajax({
                        url: '/mail/send-registration-verification-code-mail.php',
                        type: 'POST',
                        data: { 
                            email: email_regi,
                            time: currentClickTime
                        },
                        success: function(response2){
                            if(response2){
                                $("#registration-form-screen-1-container").hide();
                                $("#registration-form-screen-2-container").show();
                            }else{
                                $("#registration-screen-1-rect-text").slideDown().text("Facing problem. Connect after some time.").css("color","red");
                            }
                        }
                    })
                }else{
                    $("#registration-screen-1-rect-text").slideDown().text("This email is already registered.").css("color","red");
                }
            }
        });
        }
    })

    $("#registration-screen-2-verify-button").on("click", function() {
        let veri_code_input = $("#registration-verfication-code-feild").val();
        attempts++;
    
        if (attempts <= 5) {
            
            $.ajax({
                url: '/authentication/check-code.php',
                type: 'POST',
                data: {
                    email: email_regi,
                    code:veri_code_input,
                    time:currentClickTime
                },
                success: function(response){
                    if(response==1){
                        $("#registration-form-screen-3-container").show();
                        $("#registration-form-screen-2-container").hide();
                    }else{
                        let attemptsLeft = 5 - attempts;
                        if (attemptsLeft > 0) {
                            $("#registration-screen-2-rect-text").slideDown().text(`Wrong code. ${attemptsLeft} attempts left.`).css("color", "red");
                        } else {
                            $("#registration-screen-2-rect-text").slideDown().text("No attempts left. Please try again later.").css("color", "red");
                            window.location.replace('http://nismwala.com','_Self');
                        }
                    }
                }
            });
        }
    });
    
    $("#registration-screen-2-back-to-screen-1-button").on("click",function(){
        $("#registration-form-screen-1-container").show();
        $("#registration-form-screen-2-container").hide();
        $("#registration-screen-1-next-button").text("send new verification code");
        $("#registration-screen-1-rect-text").hide();
        attempts = 0;
        $("#registration-verfication-code-feild").val("");
        $("#registration-screen-2-rect-text").hide();
    })
    
    $("#registration-screen-3-next-button").on("click",function(){
        let pass_regi = $("#registration-password-feild").val();
        if(pass_regi.length>=8){
            password_regi = $("#registration-password-feild").val();
            $("#registration-form-screen-3-container").hide();
            $("#registration-form-screen-4-container").show();
        }else{
            $("#registration-screen-3-rect-text").slideDown().text("Password must be 8+ chars.").css("color","red")
        }
    });
    
    $("#registration-screen-4-save-button").on("click", function() {
    fname = $("#registration-fname-feild").val();
    lname = $("#registration-lname-feild").val();
    if (fname == "") {
        $("#registration-screen-4-rect-text").slideDown().css("color", "red");
    } else {
        $.ajax({
            url: '/authentication/registration-data-save.php',
            type: 'POST',
            data: {
                email: email_regi,
                fname: fname,
                lname: lname,
                phone: phone_no,
                password: password_regi
            },
            success: function(response) {
                if (response==1) {
                    $("#registration-form-screen-4-container").hide();
                    $("#registration-form-screen-5-container").show();
                    // Delay the redirection by 3 seconds
                    setTimeout(function() {
                        location.reload();
                    }, 3000);
                } else {
                    $("#registration-form-screen-3-container").hide();
                    $("#registration-form-screen-4-container").show();
                    $("#registration-status-icon").html("<i class='fa-solid fa-xmark'></i>").css("background", "red");
                    $("#registration-status-text").text("Registration Unsuccessful! Please try Again!");
                }
            }
        });
    }
});

document.getElementById('register-form-close').addEventListener('click', function() {
        document.getElementById('overlay-register').classList.remove('active');
        document.getElementById('register-form-container').classList.remove('active');
        $('#registration-email-feild').val('');
        $('#registration-screen-1-next-button').text('Next');
        $('#registration-phone-feild').val('');
        $('#registration-form-screen-1-container').show();
        $('#registration-form-screen-2-container').hide();
        $('#registration-form-screen-3-container').hide();
        $('#registration-form-screen-4-container').hide();
        $('#registration-form-screen-5-container').hide();
        $('#registration-screen-1-rect-text').hide();
        $('#registration-verfication-code-feild').val('');
        $('#registration-password-feild').val('');
        attempts = 0;
        $('#registration-screen-2-rect-text').hide();
        $('#registration-screen-3-rect-text').hide();
        $('#registration-screen-4-rect-text').hide();
    });
</script>

</body>
</html>

    
    <div id="courses-primary-container" class="poppins-regular">
        <!--<div id="con">-->
            <div id="courses-thumbnail-container">
                <img src="https://img.freepik.com/free-vector/back-end-typographic-header-software-development-process-website-interface-design-improvement-programming-coding-it-profession-isolated-flat-vector-illustration_613284-210.jpg" alt="Thumbnail for Backend Development" id="courses-thumbnail">
            </div>
            
            <div id="courses-title">Backend Development</div>
            
            <div id="courses-description">Short description for Backend Development</div>
            
