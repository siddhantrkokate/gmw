<!DOCTYPE html>
<html lang="en">
<head>
    <!-- Basic Meta Tags -->
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Courses - nismwala.com</title>
    
    <!-- Fonts Awesome -->
    <link href="../../fontawesome-free-6.5.2-web/css/fontawesome.css" rel="stylesheet" />
    <link href="../../fontawesome-free-6.5.2-web/css/brands.css" rel="stylesheet" />
    <link href="../../fontawesome-free-6.5.2-web/css/solid.css" rel="stylesheet" />
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Reddit+Sans:wght@200;300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900&display=swap" rel="stylesheet">
    
    <!-- jQuery -->
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    
    <!-- CSS -->
    <style>
        body {
            margin: 0;
        }
        
        /* Fonts */
        .reddit-sans-600 {
            font-family: "Reddit Sans", sans-serif;
            font-weight: 600;
            font-style: normal;
        }
        .poppins-regular {
            font-family: "Poppins", sans-serif;
            font-weight: 400;
            font-style: normal;
        }
        
        #courses-primary-container {
            padding: 15px 12%;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }
        
        #header-primary-container {
            position: sticky;
            top: 0;
            z-index: 1000;
            background-color: #fff;
        }

        /* General Responsive Styles */
        
        @media only screen and (min-width: 1001px){
            #courses-primary-container{
                padding: 15px 25%;
            }
        }
        
        @media only screen and (max-width: 1000px) {
            #courses-primary-container {
                padding: 15px 3%;
            }
        }

        @media only screen and (max-width: 4800px) {
            #courses-thumbnail-container {
                max-width: 100%;
            }

            #courses-thumbnail {
                width: 100%;
                border: 0.1px solid #d1d1d1;
                border-radius: 5px;
            }

            #courses-title {
                font-size: 20px;
                margin-top: 30px;
                font-weight: 500;
                text-align: center;
                margin-bottom: 20px;
            }

            #courses-description {
                font-size: 14px;
                color: #7F8C8D;
                word-spacing: 4px;
                text-align: center;
            }

            #courses-button-container {
                display: flex;
                flex-direction: row;
                margin-top: 20px;
                margin-bottom: 20px;
                width: 100%;
                padding-bottom: 20px;
                border-bottom: 0.1px solid #d1d1d1;
                margin-bottom: 20px;
            }

            #courses-price-button {
                padding: 15px 0;
                border: 0.1px solid #3c495b;
                color: #3c495b;
                border-radius: 5px;
                margin-right: 5px;
                text-align: center;
                width: 100%;
                font-size: 14px;
                font-weight: 500;
            }

            #coueses-buy-button {
                background-color: #3c495b;
                color: white;
                border: 0.1px solid #3c495b;
                border-radius: 5px;
                padding: 15px 0;
                font-size: 14px;
                width: 100%;
                margin-left: 5px;
                cursor: pointer;
                text-align: center;
            }

            #coueses-buy-button:hover {
                background-color: white;
                color: #3c495b;
            }

            #courses-usp-containers {
                font-size: 14px;
                word-spacing: 3px;
                padding-bottom: 20px;
                width: 100%;
                margin-left: 30px;
                margin-right: 30px;
            }

            #course-usp {
                margin-bottom: 10px;
            }

            #courses-brochure-container {
                display: flex;
                flex-direction: row;
                text-align: left;
                width: 100%;
                border-top: 0.1px solid #d1d1d1;
                padding-top: 20px;
                font-size: 14px;
                color: #566573;
                padding-bottom: 20px;
                border-bottom: 0.1px solid #d1d1d1;
                margin-bottom: 20px;
                cursor: pointer;
            }

            #courses-brochure-download-icon {
                margin-left: auto;
                font-weight: 300;
                padding: 0 15px;
            }

            #courses-brochure-text {
                padding-left: 15px;
            }

            #courses-faq-heading {
                font-weight: 600;
                text-align: center;
                font-size: 17px;
                margin-top: 30px;
                margin-bottom: 20px;
            }

            .courses-faq-q-container {
                width: 100%;
                margin-top: 20px;
                padding-bottom: 20px;
                border-bottom: 0.1px solid #d1d1d1;
            }

            .courses-faq-q-question-container {
                display: flex;
                flex-direction: row;
                font-size: 15px;
                font-weight: 500;
                width: 100%;
                cursor: pointer;
            }

            .courses-faq-q-more-icon-container {
                margin-left: auto;
                padding-right: 15px;
            }

            .courses-faq-q-answer-container {
                display: none;
                font-size: 14px;
                margin-bottom: 20px;
                margin-top: 20px;
                color: #566573;
            }
        }

        /* Responsive Container Widths */
        #con {
            width: 100%;
        }

        @media only screen and (min-width: 1351px) and (max-width: 2000px) {
            #con {
                width: 60%;
            }
        }

        @media only screen and (min-width: 1251px) and (max-width: 1350px) {
            #con {
                width: 70%;
            }
        }

        @media only screen and (min-width: 1151px) and (max-width: 1250px) {
            #con {
                width: 80%;
            }
        }

        @media only screen and (min-width: 1051px) and (max-width: 1150px) {
            #con {
                width: 90%;
            }
        }
    </style>

    <script>
        $(document).ready(function(){
            $('.courses-faq-q-container').click(function(){
                $(this).find('.courses-faq-q-answer-container').slideToggle();
                $(this).find('.fa-chevron-down').toggleClass('fa-chevron-up');
            });
        });
    </script>
</head>
<body>
    
    
    <!DOCTYPE html>
<html lang="en">
<head>
    
    <!-- basic meta tags -->
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Header - nismwala.com</title>
    
    <!-- fontsawesome -->
    <link href="../fontawesome-free-6.5.2-web/css/fontawesome.css" rel="stylesheet" />
    <link href="../fontawesome-free-6.5.2-web/css/brands.css" rel="stylesheet" />
    <link href="../fontawesome-free-6.5.2-web/css/solid.css" rel="stylesheet" />
    
    <!-- google fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Reddit+Sans:wght@200;300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    
    <!-- google fonts poppins -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap" rel="stylesheet">
    
    <!-- jQuery -->
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    
    <!-- css -->
    <style>
        body {
            margin: 0px;
        }
        
        /* fonts */
        .reddit-sans-600 {
            font-family: "Reddit Sans", sans-serif;
            font-optical-sizing: auto;
            font-weight: 600;
            font-style: normal;
        }
        .poppins-regular {
            font-family: "Poppins", sans-serif;
            font-weight: 400;
            font-style: normal;
        }
        
        /* - - - - - - - - - - - - - - - - - - - - - - - - - - Header - - - - - - - - - - - - - - - - - - - - - - - - - - - - */
        
        /* header */
        #header-primary-container {
            border-bottom: 0.1px solid #d1d1d1; /* bottom border of header */
            padding: 10px 0px; /* padding from top and bottom */
        }
        
        #header-secondary-container {
            display: flex; /* display all elements of header in single row */
            flex-direction: row;
            padding: 0px 12%; /* padding from left and right */
        }
        
        /* header logo */
        #header-logo-container {
            width: 70px; /* width of logo */
            cursor: pointer; /* for showing pointor when user will hover on the logo */
        }
        
        #header-logo-first {
            /* first part of the logo */
            font-size: 22px;
            font-weight: 600;
            color: #3c4852;
        }
        
        #header-logo-second {
            /* second part of the logo */
            font-size: 11px;
            color: #96a9b4;
            font-weight: 500;
        }
        
        /* header navigation menu's */
        #header-nav-container {
            display: flex;
            flex-direction: row;
            font-size: 13px;
            color: #637984;
            cursor: pointer;
            margin-left: 40px; /* margin from logo */
        }
        
        .header-nav-menu {
            /* for aligning all menu vertically center */
            align-content: center;
            justify-content: center;
            margin-left: 40px; /* margin between each menu */
        }
        
        .fa-laptop,
        .fa-newspaper,
        .fa-house {
            /* padding between menu name and its icon */
            padding-right: 10px;
        }
        
        .my-course-nav:hover,
        .course-nav:hover,
        .blogs-nav:hover {
            /* will react when user will hover on any menu */
            color: #3c4852;
        }
        
        /* authentication buttons */
        #header-authentication-btns-container {
            margin-left: auto; /* align button to right to the page */
            display: flex;
            flex-direction: row; /* displaying in single row */
            font-size: 15px;
            justify-content: center;
            align-items: center; /* align verically center */
            color: #3c495b;
            font-weight: 500;
        }
        
        #header-auth-login {
            /* login button */
            padding: 3px 15px;
            border-radius: 5px;
            margin-right: 15px;
            cursor: pointer;
        }
        
        #header-auth-login:hover {
            /* login button hover effect */
            background-color: #f0f4f7;
        }
        
        #header-auth-register {
            /* registration button */
            padding: 3px 15px;
            border-radius: 5px;
            border: 0.1px solid #3c4852;
            cursor: pointer;
        }
        
        #header-auth-register:hover {
            background-color: #f0f4f7;
        }
        
        /* - - - - - - - - -  Profile - - - - - - - - - */
        #header-profile-icon{
            display: flex;
            flex-direction: row;
            justify-content: center;
            align-items: center;
            margin-left: auto;
            background-color: #f1f1f1;
            border-radius: 25px;
            border: 1px solid #000;
            color: #000;
            font-size: 18px;
            width: 40px;
            height: 40px;
            margin-top: 4px;
            cursor: pointer;
        }
        a{
            color: #000;
            text-decoration: none;
        }
        
        
        
        
        /* - - - - - - - - - - - - - - - - - - - - - - - - -  Login - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - */
        
        /* Slide-in login form CSS */
        #login-form-container {
            position: fixed;
            top: 0;
            right: -200%;
            width: 500px;
            height: 100%;
            background-color: #fff;
            box-shadow: -2px 0 5px rgba(0, 0, 0, 0.1);
            transition: right 0.3s ease-in-out;
            z-index: 1001;
            display: flex;
            flex-direction: column;
            padding: 20px;
        }

        #login-form-container.active {
            right: 0;
        }

        #login-form-close {
            align-self: flex-end;
            cursor: pointer;
            font-size: 30px;
            color: #3c495b;
        }

        #login-form {
            display: flex;
            flex-direction: column;
            margin-top: 20px;
        }

        #login-form input {
            margin-bottom: 10px;
            padding: 10px;
            border: 1px solid #ccc;
            border-radius: 5px;
            font-size: 14px;
        }

        #login-form button {
            padding: 10px;
            background-color: #3c495b;
            color: white;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-size: 16px;
        }

        #login-form button:hover {
            background-color: #637984;
        }

        /* Overlay CSS */
        #overlay-login {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.5);
            opacity: 0;
            transition: opacity 0.3s ease-in-out;
            z-index: 1000;
            display: none;
        }

        #overlay-login.active {
            opacity: 1;
            display: block;
        }
        
        #login-form-content-container{
            padding-top: 50px;
            max-width: 100%;
        }
        
        #login-form-sec-container{
            display: flex;
            flex-direction: column;
            align-items: center; /* Center align items within the container */
            width: 100%; /* Ensure the container takes full width */
        }
        
        #auth-heading{
            font-size: 22px;
            padding-bottom: 50px;
            text-align: center;
        }
        
        #login-name-feild,
        #login-password-feild{
            padding: 15px 20px;
            width: 85%;
            margin-bottom: 12px;
            border-radius: 5px;
            outline: none;
            border: 0.1px solid #d1d1d1;
        }
        
        
        #login-rect-text{
            color: red;
            font-size: 11px;
            text-align: right;
            width: 85%;
            display: none;
        }
        
        #login-submit-btn{
            background-color: #3c495b;
            color: white;
            padding: 15px 20px;
            text-align: center;
            width: 85%;
            border-radius: 5px;
            font-size: 13px;
            margin-top: 10px;
            border: 0.1px solid #3c495b;
            cursor: pointer;
        }
        
        #login-submit-btn:hover{
            border: 0.1px solid #3c495b;
            color: #3c495b;
            background-color: white;
        }
        
        #forgot-password-link{
            margin-top: 20px;
            font-size: 11px;
            color: #808B96;
            font-weight: 300;
        }
        
                /* Slide-in register form CSS */
        #register-form-container {
            position: fixed;
            top: 0;
            right: -200%;
            width: 500px;
            height: 100%;
            background-color: #fff;
            box-shadow: -2px 0 5px rgba(0, 0, 0, 0.1);
            transition: right 0.3s ease-in-out;
            z-index: 1001;
            display: flex;
            flex-direction: column;
            padding: 20px;
        }

        #register-form-container.active {
            right: 0;
        }

        #register-form-close {
            align-self: flex-end;
            cursor: pointer;
            font-size: 30px;
            color: #3c495b;
        }

        #register-form {
            display: flex;
            flex-direction: column;
            margin-top: 20px;
        }

        #register-form input {
            margin-bottom: 10px;
            padding: 10px;
            border: 1px solid #ccc;
            border-radius: 5px;
            font-size: 14px;
        }

        #register-form button {
            padding: 10px;
            background-color: #3c495b;
            color: white;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-size: 16px;
        }

        #register-form button:hover {
            background-color: #637984;
        }

        /* Overlay CSS */
        #overlay-register {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.5);
            opacity: 0;
            transition: opacity 0.3s ease-in-out;
            z-index: 1000;
            display: none;
        }

        #overlay-register.active {
            opacity: 1;
            display: block;
        }
        
        #register-form-container{
            max-width: 100%;
        }
        
        #registration-form-screen-1-container{
            display: flex;
            flex-direction: column;
            align-items: center; /* Center align items within the container */
            width: 100%; /* Ensure the container takes full width */
        }
        
        #registration-heading{
            padding: 50px 0px;
            font-size: 22px;
            text-align: center;
        }
        
        #registration-email-feild{
            padding: 15px 20px;
            width: 85%;
            margin-bottom: 12px;
            border-radius: 5px;
            outline: none;
            border: 0.1px solid #d1d1d1;
        }
        
        #registration-phone-feild-container{
            display: flex;
            flex-direction: row;
            width: 85%;
            border: 0.1px solid #d1d1d1;
            border-radius: 5px;
            padding: 15px 20px;
            margin-bottom: 12px;
        }
        
        #registration-phone-feild-flag-container{
            width: 50px;
            height: 20px;
        }
        
        #registration-phone-input-container{
            width: 100%;
        }
        
        #registration-phone-feild{
            border: 0px solid red;
            outline: none;
        }
        
        #registration-screen-1-rect-text{
            color: red;
            font-size: 11px;
            text-align: right;
            width: 85%;
            display: none;
        }
        
        #registration-screen-1-next-button{
            background-color: #3c495b;
            color: white;
            padding: 15px 20px;
            text-align: center;
            width: 85%;
            border-radius: 5px;
            font-size: 13px;
            margin-top: 10px;
            border: 0.1px solid #3c495b;
        }
        
        
        /* screen 2 */
        
        #registration-form-screen-2-container{
            display: flex;
            flex-direction: column;
            align-items: center;
            width: 100%;
            display: none;
        }
        
        #registration-verfication-code-feild{
            padding: 15px 20px;
            width: 85%;
            margin-bottom: 12px;
            border-radius: 5px;
            outline: none;
            border: 0.1px solid #d1d1d1;
        }
        
        #registration-screen-2-rect-text{
            color: green;
            font-size: 11px;
            text-align: right;
            width: 85%;
            display: none;
        }
        
        #registration-screen-2-verify-button{
            background-color: #3c495b;
            color: white;
            padding: 15px 20px;
            text-align: center;
            width: 85%;
            border-radius: 5px;
            font-size: 13px;
            margin-top: 10px;
            border: 0.1px solid #3c495b;
        }
        
        #registration-screen-2-back-to-screen-1-button{
            background-color: white;
            color: #3c495b;
            padding: 15px 20px;
            text-align: center;
            width: 85%;
            border-radius: 5px;
            font-size: 13px;
            margin-top: 10px;
            border: 0.1px solid #3c495b;
        }
        
        /* screen 3 */
        
        #registration-form-screen-3-container{
            display: flex;
            flex-direction: column;
            align-items: center; /* Center align items within the container */
            width: 100%; /* Ensure the container takes full width */
            display: none;
        }
        
        #registration-password-feild{
            padding: 15px 20px;
            width: 85%;
            margin-bottom: 12px;
            border-radius: 5px;
            outline: none;
            border: 0.1px solid #d1d1d1;
        }
        
        #registration-screen-3-rect-text{
            color: red;
            font-size: 11px;
            text-align: right;
            width: 85%;
            display: none;
        }
        
        #registration-screen-3-next-button{
            background-color: #3c495b;
            color: white;
            padding: 15px 20px;
            text-align: center;
            width: 85%;
            border-radius: 5px;
            font-size: 13px;
            margin-top: 10px;
            border: 0.1px solid #3c495b;
        }
        
        /* screen 4 */
        
        #registration-form-screen-4-container{
            display: flex;
            flex-direction: column;
            align-items: center; /* Center align items within the container */
            width: 100%; /* Ensure the container takes full width */
            display: none;
        }
        
        #registration-fname-feild,
        #registration-lname-feild{
            padding: 15px 20px;
            width: 85%;
            margin-bottom: 12px;
            border-radius: 5px;
            outline: none;
            border: 0.1px solid #d1d1d1;
        }
        
        #registration-screen-4-save-button{
            background-color: #3c495b;
            color: white;
            padding: 15px 20px;
            text-align: center;
            width: 85%;
            border-radius: 5px;
            font-size: 13px;
            margin-top: 10px;
            border: 0.1px solid #3c495b;
        }
        
        #registration-screen-4-rect-text{
            color: red;
            font-size: 11px;
            text-align: right;
            width: 85%;
            display: none;
        }
        
        /* screen 5 */
        
        #registration-form-screen-5-container{
            display: flex;
            flex-direction: column;
            align-items: center; /* Center align items within the container */
            width: 100%; /* Ensure the container takes full width */
            display: none;
        }
    
        #registration-status-icon{
            margin-top: 130px;
            min-width: 50px;
            min-height: 50px;
            max-width: 50px;
            background-color: green;
            color: white;
            border-radius: 25px;
            font-size: 25px;
            text-align:center;
            display: flex;
            flex-direction: row;
            justify-content: center;
            align-items: center;
        }
        
        #registration-status-text{
            margin-top: 15px;
            font-size: 16px;
        }
        
                /* - - - - - - - - - - - - - - - - - - - - - - - - - Bottom navigation menu - - - - - - - - - - - - - - - - - - - - - - - - - - */
        
        /* bottom navigation = display non in screen more than 799px */
        #bottom-nav-container {
            display: none;
        }
        
        /* bottom navigation css when screen < 798 px */
        @media only screen and (max-width: 798px) {
            
            /* display non header navigation */
            #header-nav-container {
                display: none;
            }
            
            /* bottom navigation css */
            #bottom-nav-container {
                display: flex;
                flex-direction: row;
                justify-content: space-around; /* Adjusts spacing between items */
                align-items: center; /* Aligns items vertically in the center */
                position: fixed; /* Fixes the navigation at the bottom */
                bottom: 0; /* Positions it at the bottom */
                width: 100%; /* Ensures it spans the full width of the viewport */
                background-color: #fff; /* Background color of the navigation */
                border-top: 1px solid #ccc; /* Optional: adds a border at the top */
                padding: 0px 0; /* Optional: adds padding for better spacing */
                box-shadow: 0 -2px 5px rgba(0, 0, 0, 0.1); /* Optional: adds shadow for better separation */
            }
            
            #bottom-nav-container div {
                flex: 1; /* Each item takes equal space */
                text-align: center; /* Centers the text */
                color: #637984; /* Text color */
                font-size: 11px;
            }
            
            #bottom-nav-container i {
